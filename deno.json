{
  "name": "@foundatiofx/lume-theme",
  "version": "0.1.7",
  "exports": "./mod.ts",
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "mod.ts",
      "src/**/*.ts",
      "src/assets/site.css",
      "src/assets/site.js",
      "src/assets/inter-roman-latin.woff2"
    ]
  },
  "lock": true,
  "nodeModulesDir": "none",
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "shiki": "npm:shiki@3.22.0"
  },
  "tasks": {
    "check": "deno check mod.ts tests/theme_test.ts",
    "docs:build": "deno task -c docs/deno.json build",
    "docs:check": "deno task -c docs/deno.json check",
    "fmt": "deno fmt README.md deno.json mod.ts src tests docs/_config.ts docs/deno.json",
    "publish:dry-run": "deno publish --dry-run --allow-dirty",
    "test": "deno test -A",
    "fmt:check": "deno fmt --check README.md deno.json mod.ts src tests docs/_config.ts docs/deno.json"
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "dom",
      "dom.iterable",
      "esnext"
    ]
  }
}
