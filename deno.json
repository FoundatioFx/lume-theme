{
  "name": "@foundatiofx/lume-theme",
  "version": "0.1.4",
  "exports": "./mod.ts",
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "mod.ts",
      "src/**/*.ts",
      "src/assets/site.css",
      "src/assets/site.js",
      "src/assets/inter-roman-latin.woff2"
    ]
  },
  "lock": true,
  "nodeModulesDir": "none",
  "imports": {
    "shiki": "npm:shiki@3.22.0"
  },
  "tasks": {
    "check": "deno check mod.ts",
    "fmt": "deno fmt .",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "dom",
      "dom.iterable",
      "esnext"
    ]
  }
}
